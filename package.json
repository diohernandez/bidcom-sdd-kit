{
  "name": "sdd-kit",
  "version": "0.1.0",
  "description": "Spec-Driven Development Toolkit - CLI + MCP for Claude/OpenCode",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sdd": "./bin/sdd.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "cli",
    "mcp",
    "claude",
    "opencode",
    "reverse-engineering",
    "documentation"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/fs-extra": "^11.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "templates/"
  ]
}
